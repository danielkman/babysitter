{
  "name": "@a5c-ai/transport-mux",
  "version": "0.4.9",
  "type": "module",
  "license": "MIT",
  "description": "TypeScript transport and provider mux for the agent-mux proxy layer",
  "author": "a5c-ai",
  "homepage": "https://github.com/a5c-ai/babysitter#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/a5c-ai/babysitter.git",
    "directory": "packages/transport-mux"
  },
  "bugs": {
    "url": "https://github.com/a5c-ai/babysitter/issues"
  },
  "keywords": [
    "agent-mux",
    "transport",
    "provider",
    "proxy",
    "llm"
  ],
  "engines": {
    "node": ">=20.9.0"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "amux-proxy": "./dist/bin/amux-proxy.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc --build && tsc --emitDeclarationOnly --declarationMap false -p tsconfig.json",
    "test:unit": "vitest run --config ../../vitest.config.ts \"tests/**/*.test.ts\" \"tests/**/*.test.tsx\" \"src/**/*.test.ts\" \"src/**/*.test.tsx\"",
    "test:e2e": "vitest run --config ../../vitest.config.ts \"tests/e2e/**/*.test.ts\"",
    "test": "npm run test:unit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@a5c-ai/agent-mux-core": "0.4.9",
    "hono": "^4.12.14"
  }
}
