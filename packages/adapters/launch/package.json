{
  "name": "@a5c-ai/launch-adapter",
  "version": "5.1.0",
  "type": "module",
  "license": "MIT",
  "description": "Launch orchestration for adapters: plan resolution, proxy setup, harness spawning",
  "author": "a5c-ai",
  "homepage": "https://github.com/a5c-ai/babysitter/tree/main/packages/adapters/launch#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/a5c-ai/babysitter.git",
    "directory": "packages/adapters/launch"
  },
  "bugs": {
    "url": "https://github.com/a5c-ai/babysitter/issues"
  },
  "keywords": [
    "adapters",
    "launch",
    "harness",
    "coding-agent",
    "ai"
  ],
  "engines": {
    "node": ">=20.9.0"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --build && tsc --emitDeclarationOnly --declarationMap false -p tsconfig.json",
    "test": "vitest run --config ../../../vitest.config.ts \"tests/**/*.test.ts\" \"src/**/*.test.ts\"",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@a5c-ai/comm-adapter": "5.1.0",
    "@a5c-ai/adapters-codecs": "5.1.0",
    "@a5c-ai/atlas": "5.1.0",
    "@a5c-ai/transport-adapter": "5.1.0"
  },
  "optionalDependencies": {
    "node-pty": "^1.0.0"
  },
  "atlas": {
    "layers": [
      "L8"
    ],
    "muxes": [
      "agent-launch-adapter"
    ]
  }
}
