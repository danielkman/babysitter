{
  "name": "@a5c-ai/genty-ui",
  "version": "6.0.0",
  "type": "module",
  "license": "MIT",
  "description": "Shared UI foundation and session-flow projection surface for browser and React Native adapters apps",
  "author": "a5c-ai",
  "homepage": "https://github.com/a5c-ai/babysitter/tree/main/packages/genty/ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/a5c-ai/babysitter.git",
    "directory": "packages/genty/ui"
  },
  "bugs": {
    "url": "https://github.com/a5c-ai/babysitter/issues"
  },
  "keywords": [
    "adapters",
    "ui",
    "session-flow",
    "timeline",
    "realtime",
    "react-native-web",
    "react-native",
    "gateway"
  ],
  "engines": {
    "node": ">=20.9.0"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./gateway": {
      "import": {
        "types": "./dist/gateway.d.ts",
        "default": "./dist/gateway.js"
      }
    },
    "./protocol": {
      "import": {
        "types": "./dist/protocol/v1.d.ts",
        "default": "./dist/protocol/v1.js"
      }
    },
    "./session-flow": {
      "import": {
        "types": "./dist/session-flow.d.ts",
        "default": "./dist/session-flow.js"
      }
    },
    "./agent": {
      "import": {
        "types": "./dist/components/Agent/index.d.ts",
        "default": "./dist/components/Agent/index.js"
      }
    },
    "./chat": {
      "import": {
        "types": "./dist/components/Chat/index.d.ts",
        "default": "./dist/components/Chat/index.js"
      }
    },
    "./kanban": {
      "import": {
        "types": "./dist/components/Kanban/index.d.ts",
        "default": "./dist/components/Kanban/index.js"
      }
    },
    "./workspace": {
      "import": {
        "types": "./dist/components/Workspace/index.d.ts",
        "default": "./dist/components/Workspace/index.js"
      }
    },
    "./memory": {
      "import": {
        "types": "./dist/components/Memory/index.d.ts",
        "default": "./dist/components/Memory/index.js"
      }
    },
    "./session": {
      "import": {
        "types": "./dist/components/Session/index.d.ts",
        "default": "./dist/components/Session/index.js"
      }
    },
    "./observability": {
      "import": {
        "types": "./dist/components/Observability/index.d.ts",
        "default": "./dist/components/Observability/index.js"
      }
    },
    "./primitives": {
      "import": {
        "types": "./dist/components/primitives/index.d.ts",
        "default": "./dist/components/primitives/index.js"
      }
    },
    "./rendering": {
      "import": {
        "types": "./dist/components/Rendering/index.d.ts",
        "default": "./dist/components/Rendering/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "npm run clean && npm run codegen && tsc --build && tsc --emitDeclarationOnly --declarationMap false -p tsconfig.json",
    "build:realtime": "npm run build --workspace=@a5c-ai/atlas && npm run build --workspace=@a5c-ai/comm-adapter && npm run build",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "codegen": "tsx src/codegen/swift-types.ts && tsx src/codegen/kotlin-types.ts",
    "test": "vitest run --root ../../.. --config vitest.config.ts packages/genty/ui",
    "test:realtime": "vitest run --root ../../.. --config vitest.config.ts \"packages/genty/ui/src/session-flow*.test.ts\" \"packages/genty/ui/src/screens/SessionDetailScreen.test.tsx\" \"packages/genty/ui/src/release-verification.test.ts\"",
    "verify:release": "node ./scripts/verify-release.mjs",
    "prepublishOnly": "npm run build:realtime && npm run test:realtime && npm run verify:release"
  },
  "dependencies": {
    "@a5c-ai/comm-adapter": "6.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-native": "^0.85.3",
    "react-native-web": "^0.21.2",
    "ts-morph": "^25.0.1",
    "ws": "^8.18.3",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/react": "^19.1.0"
  },
  "atlas": {
    "layers": [
      "L6"
    ],
    "muxes": [
      "adapters"
    ]
  }
}
