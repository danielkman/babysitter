{
  "name": "@a5c-ai/genty-tui",
  "version": "6.0.0",
  "type": "module",
  "license": "MIT",
  "description": "Extensible Ink-based TUI for adapters, with a plugin-first architecture",
  "author": "a5c-ai",
  "homepage": "https://github.com/a5c-ai/babysitter/tree/main/packages/genty/tui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/a5c-ai/babysitter.git",
    "directory": "packages/genty/tui"
  },
  "bugs": {
    "url": "https://github.com/a5c-ai/babysitter/issues"
  },
  "keywords": [
    "adapters",
    "tui",
    "ink",
    "react",
    "plugins"
  ],
  "engines": {
    "node": ">=20.9.0"
  },
  "bin": {
    "adapters-tui": "./dist/bin/adapters-tui.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./plugin": {
      "import": {
        "types": "./dist/plugin.d.ts",
        "default": "./dist/plugin.js"
      }
    }
  },
  "files": [
    "dist",
    "specs",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "cd ../../.. && node scripts/adapters-build.cjs build packages/genty/tui",
    "build:local": "tsc --build && tsc --emitDeclarationOnly --declarationMap false -p tsconfig.json",
    "start": "node ./dist/bin/adapters-tui.js",
    "dev": "npm run build && npm start",
    "test": "cd ../../.. && node scripts/adapters-build.cjs test packages/genty/tui",
    "verify:release": "node ./scripts/verify-release.mjs",
    "prepublishOnly": "npm run build && npm run verify:release"
  },
  "dependencies": {
    "@a5c-ai/adapters": "6.0.0",
    "@a5c-ai/adapters-cli": "6.0.0",
    "@a5c-ai/comm-adapter": "6.0.0",
    "@a5c-ai/adapters-observability": "6.0.0",
    "ink": "^5.0.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "ink-testing-library": "^4.0.0"
  },
  "atlas": {
    "layers": [
      "L6"
    ],
    "muxes": [
      "adapters"
    ]
  }
}
