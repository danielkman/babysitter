{
  "name": "@a5c-ai/babysitter-paperclip",
  "version": "5.0.0",
  "description": "Babysitter orchestration plugin for Paperclip AI",
  "license": "MIT",
  "type": "module",
  "main": "dist/worker.js",
  "files": [
    "dist/",
    "README.md",
    "versions.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/a5c-ai/babysitter.git",
    "directory": "plugins/babysitter-paperclip"
  },
  "homepage": "https://github.com/a5c-ai/babysitter/tree/main/plugins/babysitter-paperclip#readme",
  "bugs": {
    "url": "https://github.com/a5c-ai/babysitter/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "dev": "paperclip-plugin-dev-server --root . --ui-dir dist/ui --port 4177",
    "test": "vitest run",
    "validate:ci": "npm test",
    "deploy": "npm publish --access public",
    "deploy:staging": "npm publish --access public --tag staging"
  },
  "peerDependencies": {
    "@paperclipai/plugin-sdk": ">=0.1.0"
  },
  "dependencies": {
    "@a5c-ai/babysitter-sdk": "5.0.0"
  },
  "devDependencies": {
    "@paperclipai/plugin-sdk": "latest",
    "esbuild": "^0.21.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@types/react": "^19.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
