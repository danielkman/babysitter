{
  "name": "babysitter",
  "version": "5.0.0",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "packages/tula-core",
    "packages/agent-platform",
    "packages/tula-runtime",
    "packages/atlas",
    "packages/babysitter",
    "packages/babysitter-tui-plugins",
    "packages/cloud",
    "packages/observer-dashboard",
    "packages/sdk",
    "packages/tula",
    "packages/agent-mux/*",
    "packages/atlas/*",
    "packages/agent-mux/hooks/core",
    "packages/agent-mux/hooks/cli",
    "packages/agent-mux/hooks/adapter-claude",
    "packages/agent-mux/hooks/adapter-codex",
    "packages/agent-mux/hooks/adapter-gemini",
    "packages/agent-mux/hooks/adapter-copilot",
    "packages/agent-mux/hooks/adapter-cursor",
    "packages/agent-mux/hooks/adapter-pi",
    "packages/agent-mux/hooks/adapter-oh-my-pi",
    "packages/agent-mux/hooks/adapter-opencode",
    "packages/agent-mux/hooks/adapter-openclaw",
    "packages/agent-mux/hooks/adapter-hermes",
    "packages/krate/core",
    "packages/krate/sdk",
    "packages/krate/cli",
    "packages/krate/web",
    "packages/krate/jitsi-agent-sidecar"
  ],
  "scripts": {
    "check:library-syntax": "node ./scripts/validate-library-js-syntax.cjs",
    "verify:metadata": "node ./scripts/check-package-metadata.cjs",
    "validate:processes": "node ./scripts/validate-process.mjs",
    "verify:library-metadata": "node packages/atlas/scripts/verify-library-metadata.mjs",
    "test:atlas-catalog-contracts": "npm exec --yes --package=vitest -- vitest run --config vitest.config.ts \"packages/atlas/src/catalog/catalog.test.ts\" \"packages/atlas/src/catalog/discovery.contract.test.ts\" \"packages/atlas/src/catalog/sdk.contract.test.ts\" \"packages/atlas/src/catalog/discovery.packaged.test.ts\" \"packages/atlas/src/catalog/export.contract.test.ts\" \"packages/atlas/src/catalog/consumer-imports.contract.test.ts\" \"packages/atlas/src/catalog/workspace-metadata.contract.test.ts\" \"packages/atlas/src/catalog/final-removal.contract.test.ts\" \"packages/sdk/src/harness/amuxFallbackMetadata.contract.test.ts\" \"packages/agent-mux/hooks/core/src/discovery/__tests__/detector.contract.test.ts\" \"packages/agent-mux/core/tests/host-detection.contract.test.ts\" \"packages/agent-mux/core/tests/invocation.contract.test.ts\" \"packages/agent-mux/extensions/src/__tests__/targets.contract.test.ts\"",
    "verify:v6:seams": "npm run test:seams --workspace=@a5c-ai/agent-platform",
    "test:architecture": "npm run verify:v6:seams && node ./scripts/check-architecture-boundaries.cjs",
    "test:package-renames": "node ./scripts/check-package-renames.cjs",
    "test:binary-renames": "node ./scripts/check-binary-renames.cjs",
    "sync:sdk-command-templates": "node ./scripts/sync-sdk-command-templates.cjs",
    "check:sdk-command-templates": "node ./scripts/sync-sdk-command-templates.cjs --check",
    "sync:plugin-commands": "node ./scripts/sync-plugin-commands.cjs",
    "check:plugin-commands": "node ./scripts/sync-plugin-commands.cjs --check",
    "test:sdk": "npm run test --workspace=@a5c-ai/babysitter-sdk",
    "test:library": "vitest run --config library/vitest.config.mjs",
    "test:shared": "node --test library/processes/shared/__tests__/*.test.mjs",
    "build:sdk": "npm run build --workspace=@a5c-ai/atlas && npm run build --workspace=@a5c-ai/agent-mux-tasks && npm run build --workspace=@a5c-ai/babysitter-sdk",
    "build:agent-mux:non-realtime": "npm run build --workspace=@a5c-ai/agent-mux-observability && npm run build --workspace=@a5c-ai/agent-mux-comm && npm run build --workspace=@a5c-ai/agent-mux-adapters && npm run build --workspace=@a5c-ai/agent-mux-gateway && npm run build --workspace=@a5c-ai/agent-mux-transport && npm run build --workspace=@a5c-ai/agent-mux-cli && npm run build --workspace=@a5c-ai/agent-mux",
    "build:runtime:tula-core-deps": "npm run build:sdk && npm run build:agent-mux:non-realtime && npm run build --workspace=@a5c-ai/tula-runtime",
    "build:runtime:agent-platform-deps": "npm run build:runtime:tula-core-deps && npm run build --workspace=@a5c-ai/tula-core",
    "build:runtime": "npm run build:runtime:agent-platform-deps && npm run build --workspace=@a5c-ai/agent-platform",
    "token:eval": "bash scripts/eval-compression.sh",
    "build:observer": "npm run build --workspace=@a5c-ai/babysitter-observer-dashboard",
    "verify:observer-release": "npm run verify:release --workspace=@a5c-ai/babysitter-observer-dashboard",
    "test:observer": "npm run test --workspace=@a5c-ai/babysitter-observer-dashboard",
    "build:cloud": "npm run build --workspace=@a5c-ai/cloud",
    "test:cloud": "npm run test --workspace=@a5c-ai/cloud",
    "coverage:cloud": "npm run test:coverage --workspace=@a5c-ai/cloud",
    "verify:cloud-release": "npm run verify:release --workspace=@a5c-ai/cloud",
    "deploy:cloud:staging": "npm run build:cloud && node ./packages/cloud/dist/cli.js install --env staging",
    "deploy:cloud:prod": "npm run build:cloud && node ./packages/cloud/dist/cli.js install --env prod",
    "build:realtime-flow": "npm run build:realtime --workspace=@a5c-ai/agent-mux-ui && npm run build:realtime --workspace=@a5c-ai/agent-mux-webui",
    "test:realtime-flow": "npm run test:realtime --workspace=@a5c-ai/agent-mux-ui && npm run test:realtime --workspace=@a5c-ai/agent-mux-webui",
    "verify:realtime-flow-release": "npm run verify:release --workspace=@a5c-ai/agent-mux-ui && npm run verify:release --workspace=@a5c-ai/agent-mux-webui",
    "build:atlas": "npm run build --workspace=@a5c-ai/atlas",
    "build:agent-mux": "node scripts/agent-mux-build.cjs build",
    "test:agent-mux": "node scripts/agent-mux-build.cjs build && node scripts/agent-mux-build.cjs test",
    "build:krate": "npm run build --workspace=@a5c-ai/krate",
    "build:krate-web": "npm run build --workspace=@a5c-ai/krate-web",
    "build:hooks-mux": "node scripts/hooks-mux-build.cjs build",
    "test:krate": "npm run test --workspace=@a5c-ai/krate",
    "test:hooks-mux": "node scripts/hooks-mux-build.cjs test",
    "lint:hooks-mux": "node scripts/hooks-mux-build.cjs lint",
    "generate:plugins": "node scripts/generate-plugins.mjs --output artifacts/generated-plugins",
    "compare:plugins": "npm run generate:plugins",
    "generate:process-library-docs": "node ./scripts/generate-process-library-doc-artifacts.cjs",
    "build:agent-mux-extensions": "npm run build --workspace=@a5c-ai/agent-mux-extensions",
    "build:extension-mux": "npm run build --workspace=@a5c-ai/agent-mux-extensions",
    "test:extension-mux": "npm run test --workspace=@a5c-ai/agent-mux-extensions",
    "docs:prepare": "node ./scripts/generate-process-library-doc-artifacts.cjs && node ./scripts/generate-cli-examples-artifacts.cjs && node ./scripts/ensure-webpackbar-patch.cjs",
    "docs:examples:generate": "node ./scripts/generate-cli-examples-artifacts.cjs",
    "docs:examples:smoke": "npm run smoke:cli --workspace=@a5c-ai/babysitter-sdk",
    "docs:examples:verify": "npm run build --workspace=@a5c-ai/babysitter-sdk && npm run docs:prepare && npm run docs:examples:smoke && npm run docs:qa",
    "docs:lint:markdown": "markdownlint-cli2",
    "docs:lint:style": "node ./scripts/docs-style-check.cjs",
    "docs:lint": "npm run docs:lint:markdown && npm run docs:lint:style",
    "docs:snippets": "node ./scripts/docs-code-samples-check.cjs",
    "docs:links": "node ./scripts/docs-link-check.cjs && node ./scripts/docs-strict-build.cjs",
    "docs:freshness": "node ./scripts/docs-freshness-report.cjs",
    "docs:qa": "npm run docs:lint && npm run docs:snippets && npm run docs:links && npm run docs:freshness",
    "docs:ci": "npm run docs:qa",
    "docs:dev": "npm run docs:prepare && docusaurus start docs-site --host 0.0.0.0",
    "docs:build": "npm run docs:prepare && docusaurus build docs-site",
    "docs:serve": "docusaurus serve docs-site/build",
    "docs:clear": "docusaurus clear docs-site",
    "sync:external-plugins": "node scripts/sync-external-plugin-repos.mjs",
    "validate:edges": "node packages/atlas/scripts/validate-edges.mjs",
    "test:e2e:live-stack:primary": "vitest run --config vitest.config.ts packages/agent-mux/cli/tests/live-stack/primary-live-runner.test.ts",
    "test:e2e:live-stack:framework": "vitest run --config vitest.config.ts packages/agent-mux/cli/tests/live-stack/scenario-contract.test.ts",
    "test:e2e:live-stack": "npm run test:e2e:live-stack:framework && npm run test:e2e:live-stack:primary",
    "coverage:e2e:live-stack": "node scripts/live-stack-coverage-report.cjs",
    "test:e2e:live-stack:pipeline": "vitest run --config vitest.config.ts packages/agent-mux/cli/tests/live-stack/pipeline-scenario.test.ts",
    "test:e2e:agent-mux-hooks-mux": "vitest run --config vitest.config.ts packages/agent-mux/cli/tests/e2e/agent-mux-hooks-mux.pipeline.test.ts",
    "test:e2e:agent-mux-no-model-stack": "vitest run --config vitest.config.ts packages/agent-mux/cli/tests/e2e/agent-mux-no-model-stack.pipeline.test.ts"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.152",
    "@docusaurus/core": "3.10.1",
    "@docusaurus/preset-classic": "3.10.1",
    "@mdx-js/react": "^3.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "4.1.6",
    "markdownlint-cli2": "0.22.1",
    "prism-react-renderer": "^2.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom-v6": "npm:react-router-dom@^6.30.2",
    "vitest": "4.1.6",
    "webpackbar": "file:third_party/webpackbar"
  },
  "overrides": {
    "webpackbar": "file:third_party/webpackbar",
    "@react-native/codegen": "0.85.3",
    "chromium-edge-launcher": "^2.0.1",
    "babel-plugin-istanbul": "^8.0.0",
    "test-exclude": "^8.0.0",
    "sockjs": {
      "uuid": "^11.1.0"
    },
    "xcode": {
      "uuid": "^11.1.0"
    },
    "node-domexception": "$node-domexception",
    "serialize-javascript": "^7.0.5",
    "postcss": "^8.5.10",
    "postcss-custom-media": "^12.0.1",
    "postcss-custom-properties": "^15.0.1",
    "postcss-custom-selectors": "^9.0.1",
    "@csstools/postcss-media-minmax": "^3.0.3",
    "@csstools/cascade-layer-name-parser": "^3.0.0",
    "@csstools/media-query-list-parser": "^5.0.0"
  },
  "dependencies": {
    "@a5c-ai/agent-mux": "^5.0.0",
    "@a5c-ai/compendium": "^0.1.0",
    "@earendil-works/pi-coding-agent": "0.75.5",
    "@modelcontextprotocol/sdk": "1.29.0",
    "expo": "^55.0.24",
    "expo-notifications": "^55.0.23",
    "express-rate-limit": "8.5.1",
    "node-domexception": "file:third_party/node-domexception",
    "react-native": "^0.85.3"
  }
}
