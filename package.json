{
  "name": "babysitter",
  "version": "6.0.1",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "packages/genty/core",
    "packages/genty/platform",
    "packages/genty/runtime",
    "packages/atlas",
    "packages/babysitter",
    "packages/genty/tui-plugins",
    "packages/kradle/installer",
    "packages/observer-dashboard",
    "packages/babysitter-sdk",
    "packages/genty/cli",
    "packages/adapters/*",
    "packages/atlas/*",
    "packages/adapters/hooks/core",
    "packages/adapters/hooks/cli",
    "packages/adapters/hooks/adapter-claude",
    "packages/adapters/hooks/adapter-codex",
    "packages/adapters/hooks/adapter-gemini",
    "packages/adapters/hooks/adapter-copilot",
    "packages/adapters/hooks/adapter-cursor",
    "packages/adapters/hooks/adapter-pi",
    "packages/adapters/hooks/adapter-oh-my-pi",
    "packages/adapters/hooks/adapter-opencode",
    "packages/adapters/hooks/adapter-openclaw",
    "packages/adapters/hooks/adapter-antigravity",
    "packages/adapters/hooks/adapter-hermes",
    "packages/adapters/hooks/adapter-genty",
    "packages/kradle/core",
    "packages/kradle/sdk",
    "packages/kradle/cli",
    "packages/kradle/web",
    "packages/kradle/jitsi-agent-sidecar",
    "packages/genty/ui",
    "packages/genty/web-app",
    "packages/genty/desktop-app",
    "packages/genty/tui",
    "packages/genty/mobile-android-app",
    "packages/genty/mobile-ios-app",
    "packages/genty/tv-androidtv-app",
    "packages/genty/tv-appletv-app",
    "packages/genty/watch-watchos-app",
    "packages/genty/watch-wearos-app"
  ],
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "guard:packages": "node ./scripts/guard-package-integrity.cjs",
    "check:library-syntax": "node ./scripts/validate-library-js-syntax.cjs",
    "verify:metadata": "node ./scripts/check-package-metadata.cjs",
    "validate:processes": "node ./scripts/validate-process.mjs",
    "verify:library-metadata": "node packages/atlas/scripts/verify-library-metadata.mjs",
    "test:atlas-catalog-contracts": "npm exec --yes --package=vitest -- vitest run --config vitest.config.ts \"packages/atlas/src/catalog/catalog.test.ts\" \"packages/atlas/src/catalog/discovery.contract.test.ts\" \"packages/atlas/src/catalog/sdk.contract.test.ts\" \"packages/atlas/src/catalog/discovery.packaged.test.ts\" \"packages/atlas/src/catalog/export.contract.test.ts\" \"packages/atlas/src/catalog/consumer-imports.contract.test.ts\" \"packages/atlas/src/catalog/workspace-metadata.contract.test.ts\" \"packages/atlas/src/catalog/final-removal.contract.test.ts\" \"packages/babysitter-sdk/src/harness/adapterFallbackMetadata.contract.test.ts\" \"packages/adapters/hooks/core/src/discovery/__tests__/detector.contract.test.ts\" \"packages/adapters/core/tests/host-detection.contract.test.ts\" \"packages/adapters/core/tests/invocation.contract.test.ts\" \"packages/adapters/extensions/src/__tests__/targets.contract.test.ts\"",
    "verify:v6:seams": "npm run test:seams --workspace=@a5c-ai/genty-platform",
    "test:architecture": "npm run verify:v6:seams && node ./scripts/check-architecture-boundaries.cjs",
    "test:package-renames": "node ./scripts/check-package-renames.cjs",
    "test:binary-renames": "node ./scripts/check-binary-renames.cjs",
    "sync:sdk-command-templates": "node ./scripts/sync-sdk-command-templates.cjs",
    "check:sdk-command-templates": "node ./scripts/sync-sdk-command-templates.cjs --check",
    "sync:plugin-commands": "node ./scripts/sync-plugin-commands.cjs",
    "check:plugin-commands": "node ./scripts/sync-plugin-commands.cjs --check",
    "test:sdk": "npm run test --workspace=@a5c-ai/babysitter-sdk",
    "test:library": "vitest run --config library/vitest.config.mjs",
    "test:shared": "node --test library/processes/shared/__tests__/*.test.mjs",
    "build:sdk": "npm run build --workspace=@a5c-ai/atlas && npm run build --workspace=@a5c-ai/tasks-adapter && npm run build --workspace=@a5c-ai/babysitter-sdk",
    "build:adapters:non-realtime": "npm run build --workspace=@a5c-ai/adapters-observability && npm run build --workspace=@a5c-ai/comm-adapter && npm run build --workspace=@a5c-ai/adapters-codecs && npm run build --workspace=@a5c-ai/adapters-gateway && npm run build --workspace=@a5c-ai/transport-adapter && npm run build --workspace=@a5c-ai/adapters-cli && npm run build --workspace=@a5c-ai/adapters",
    "build:runtime:genty-core-deps": "npm run build:sdk && npm run build:adapters:non-realtime && npm run build --workspace=@a5c-ai/genty-runtime",
    "build:runtime:genty-platform-deps": "npm run build:runtime:genty-core-deps && npm run build --workspace=@a5c-ai/genty-core",
    "build:runtime": "npm run build:runtime:genty-platform-deps && npm run build --workspace=@a5c-ai/genty-platform",
    "token:eval": "bash scripts/eval-compression.sh",
    "build:observer": "npm run build --workspace=@a5c-ai/babysitter-observer-dashboard",
    "verify:observer-release": "npm run verify:release --workspace=@a5c-ai/babysitter-observer-dashboard",
    "test:observer": "npm run test --workspace=@a5c-ai/babysitter-observer-dashboard",
    "build:cloud": "npm run build --workspace=@a5c-ai/kradle-installer",
    "test:cloud": "npm run test --workspace=@a5c-ai/kradle-installer",
    "coverage:cloud": "npm run test:coverage --workspace=@a5c-ai/kradle-installer",
    "verify:cloud-release": "npm run verify:release --workspace=@a5c-ai/kradle-installer",
    "deploy:cloud:staging": "npm run build:cloud && node ./packages/kradle/installer/dist/cli.js install --env staging",
    "deploy:cloud:prod": "npm run build:cloud && node ./packages/kradle/installer/dist/cli.js install --env prod",
    "build:realtime-flow": "npm run build:realtime --workspace=@a5c-ai/genty-ui",
    "test:realtime-flow": "npm run test:realtime --workspace=@a5c-ai/genty-ui",
    "verify:realtime-flow-release": "npm run verify:release --workspace=@a5c-ai/genty-ui",
    "build:atlas": "npm run build --workspace=@a5c-ai/atlas",
    "build:adapters": "node scripts/adapters-build.cjs build",
    "test:adapters": "node scripts/adapters-build.cjs build && node scripts/adapters-build.cjs test",
    "build:kradle": "npm run build --workspace=@a5c-ai/kradle",
    "build:kradle-web": "npm run build --workspace=@a5c-ai/kradle-web",
    "build:hooks-adapter": "node scripts/hooks-adapter-build.cjs build",
    "test:kradle": "npm run test --workspace=@a5c-ai/kradle",
    "test:hooks-adapter": "node scripts/hooks-adapter-build.cjs test",
    "lint:hooks-adapter": "node scripts/hooks-adapter-build.cjs lint",
    "generate:plugins": "node scripts/generate-plugins.mjs --output artifacts/generated-plugins",
    "compare:plugins": "npm run generate:plugins",
    "generate:atlas-plugins": "node scripts/generate-atlas-plugins.mjs --output artifacts/generated-atlas-plugins",
    "test:atlas-plugins": "node scripts/test-atlas-plugins.mjs",
    "generate:process-library-docs": "node ./scripts/generate-process-library-doc-artifacts.cjs",
    "build:adapters-extensions": "npm run build --workspace=@a5c-ai/extensions-adapter",
    "build:extension-mux": "npm run build --workspace=@a5c-ai/extensions-adapter",
    "test:extension-mux": "npm run test --workspace=@a5c-ai/extensions-adapter",
    "docs:prepare": "node ./scripts/generate-process-library-doc-artifacts.cjs && node ./scripts/generate-cli-examples-artifacts.cjs && node ./scripts/ensure-webpackbar-patch.cjs",
    "docs:examples:generate": "node ./scripts/generate-cli-examples-artifacts.cjs",
    "docs:examples:smoke": "npm run smoke:cli --workspace=@a5c-ai/babysitter-sdk",
    "docs:examples:verify": "npm run build --workspace=@a5c-ai/babysitter-sdk && npm run docs:prepare && npm run docs:examples:smoke && npm run docs:qa",
    "docs:lint:markdown": "markdownlint-cli2",
    "docs:lint:style": "node ./scripts/docs-style-check.cjs",
    "docs:lint": "npm run docs:lint:markdown && npm run docs:lint:style",
    "docs:snippets": "node ./scripts/docs-code-samples-check.cjs",
    "docs:links": "node ./scripts/docs-link-check.cjs && node ./scripts/docs-strict-build.cjs",
    "docs:freshness": "node ./scripts/docs-freshness-report.cjs",
    "docs:qa": "npm run docs:lint && npm run docs:snippets && npm run docs:links && npm run docs:freshness",
    "docs:ci": "npm run docs:qa",
    "docs:dev": "npm run docs:prepare && docusaurus start docs-site --host 0.0.0.0",
    "docs:build": "npm run docs:prepare && docusaurus build docs-site",
    "docs:serve": "docusaurus serve docs-site/build",
    "docs:clear": "docusaurus clear docs-site",
    "sync:external-plugins": "node scripts/sync-external-plugin-repos.mjs",
    "sync:atlas-plugins": "node scripts/sync-atlas-plugin-repos.mjs",
    "validate:edges": "node packages/atlas/scripts/validate-edges.mjs",
    "test:e2e:live-stack:primary": "vitest run --config packages/adapters/cli/vitest.config.ts packages/adapters/cli/tests/live-stack/primary-live-runner.test.ts",
    "test:e2e:live-stack:framework": "vitest run --config packages/adapters/cli/vitest.config.ts packages/adapters/cli/tests/live-stack/scenario-contract.test.ts",
    "test:e2e:live-stack": "npm run test:e2e:live-stack:framework && npm run test:e2e:live-stack:primary",
    "coverage:e2e:live-stack": "node scripts/live-stack-coverage-report.cjs",
    "test:e2e:live-stack:pipeline": "vitest run --config packages/adapters/cli/vitest.config.ts packages/adapters/cli/tests/live-stack/pipeline-scenario.test.ts",
    "test:e2e:live-stack:documented-install": "vitest run --config packages/adapters/cli/vitest.config.ts packages/adapters/cli/tests/live-stack/documented-install.test.ts",
    "test:e2e:adapters-hooks-adapter": "vitest run --config packages/adapters/cli/vitest.config.ts packages/adapters/cli/tests/e2e/adapters-hooks-adapter.pipeline.test.ts",
    "test:e2e:adapters-no-model-stack": "vitest run --config packages/adapters/cli/vitest.config.ts packages/adapters/cli/tests/e2e/adapters-no-model-stack.pipeline.test.ts"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.152",
    "@docusaurus/core": "3.10.1",
    "@docusaurus/preset-classic": "3.10.1",
    "@mdx-js/react": "^3.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "4.1.6",
    "markdownlint-cli2": "0.22.1",
    "prism-react-renderer": "^2.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom-v6": "npm:react-router-dom@^6.30.2",
    "vitest": "4.1.6",
    "webpackbar": "file:third_party/webpackbar"
  },
  "overrides": {
    "webpackbar": "file:third_party/webpackbar",
    "@react-native/codegen": "0.85.3",
    "chromium-edge-launcher": "^2.0.1",
    "babel-plugin-istanbul": "^8.0.0",
    "test-exclude": "^8.0.0",
    "sockjs": {
      "uuid": "^11.1.0"
    },
    "xcode": {
      "uuid": "^11.1.0"
    },
    "node-domexception": "$node-domexception",
    "serialize-javascript": "^7.0.5",
    "postcss": "^8.5.10",
    "postcss-custom-media": "^12.0.1",
    "postcss-custom-properties": "^15.0.1",
    "postcss-custom-selectors": "^9.0.1",
    "@csstools/postcss-media-minmax": "^3.0.3",
    "@csstools/cascade-layer-name-parser": "^3.0.0",
    "@csstools/media-query-list-parser": "^5.0.0"
  },
  "dependencies": {
    "@a5c-ai/adapters": "^6.0.0",
    "@a5c-ai/compendium": "^0.1.0",
    "@earendil-works/pi-coding-agent": "0.75.5",
    "@modelcontextprotocol/sdk": "1.29.0",
    "expo": "^55.0.24",
    "expo-notifications": "^55.0.23",
    "express-rate-limit": "8.5.1",
    "node-domexception": "file:third_party/node-domexception",
    "react-native": "^0.85.3"
  }
}
